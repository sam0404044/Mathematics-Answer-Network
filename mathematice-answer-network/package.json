    "test:smoke": "node --env-file=.env.local scripts/e2e-smoke.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.8.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.1",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
